{
  "name": "@valbuild/richtext",
  "version": "0.62.2",
  "private": false,
  "description": "Val - RichText JSX",
  "sideEffects": false,
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "jest"
  },
  "dependencies": {
    "@valbuild/core": "*"
  },
  "devDependencies": {
    "@testing-library/react": "^14.0.0",
    "@types/react": "^18.2.38",
    "jest-environment-jsdom": "^29.5.0"
  },
  "preconstruct": {
    "entrypoints": [
      "./index.ts",
      "./jsx-runtime.js",
      "./jsx-dev-runtime.js"
    ],
    "exports": {
      "envConditions": [
        "browser",
        "worker"
      ]
    }
  },
  "externals": [
    "react"
  ],
  "main": "dist/valbuild-richtext.cjs.js",
  "module": "dist/valbuild-richtext.esm.js",
  "browser": {
    "./dist/valbuild-richtext.esm.js": "./dist/valbuild-richtext.browser.esm.js"
  },
  "exports": {
    ".": {
      "module": {
        "worker": "./dist/valbuild-richtext.worker.esm.js",
        "browser": "./dist/valbuild-richtext.browser.esm.js",
        "default": "./dist/valbuild-richtext.esm.js"
      },
      "default": "./dist/valbuild-richtext.cjs.js"
    },
    "./jsx-runtime": {
      "module": {
        "worker": "./jsx-runtime/dist/valbuild-richtext-jsx-runtime.worker.esm.js",
        "browser": "./jsx-runtime/dist/valbuild-richtext-jsx-runtime.browser.esm.js",
        "default": "./jsx-runtime/dist/valbuild-richtext-jsx-runtime.esm.js"
      },
      "default": "./jsx-runtime/dist/valbuild-richtext-jsx-runtime.cjs.js"
    },
    "./jsx-dev-runtime": {
      "module": {
        "worker": "./jsx-dev-runtime/dist/valbuild-richtext-jsx-dev-runtime.worker.esm.js",
        "browser": "./jsx-dev-runtime/dist/valbuild-richtext-jsx-dev-runtime.browser.esm.js",
        "default": "./jsx-dev-runtime/dist/valbuild-richtext-jsx-dev-runtime.esm.js"
      },
      "default": "./jsx-dev-runtime/dist/valbuild-richtext-jsx-dev-runtime.cjs.js"
    },
    "./package.json": "./package.json"
  },
  "types": "dist/valbuild-richtext.cjs.d.ts",
  "files": [
    "dist",
    "jsx-runtime",
    "jsx-dev-runtime"
  ]
}
